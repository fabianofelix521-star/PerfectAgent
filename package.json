  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n web,api -c blue,green \"vite\" \"npm run server\"",
    "dev:web": "vite",
    "server": "tsx watch server/index.ts",
    "start": "tsx server/index.ts",
    "build": "vite build",
    "build:single": "VITE_SINGLE_FILE=true vite build",
    "deploy:casaos": "bash scripts/deploy-casaos.sh",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit && tsc --noEmit -p server/tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
